{
  "name": "taro-vue3-zhihudaily",
  "type": "commonjs",
  "version": "0.3.0",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "description": "taro-vue3-zhihudaily",
  "license": "MIT",
  "author": {
    "name": "ntnyq",
    "email": "ntnyq13@gmail.com"
  },
  "scripts": {
    "build": "taro build --type weapp",
    "dev": "pnpm run build --watch",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "eslint",
    "prepare": "husky",
    "release": "runs-s release:check release:version",
    "release:check": "run-s lint format:check typecheck",
    "release:version": "bumpp",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@babel/runtime": "^8.0.0",
    "@nutui/icons-vue-taro": "^0.0.9",
    "@nutui/nutui-taro": "^4.3.14",
    "@tarojs/components": "^4.2.0",
    "@tarojs/plugin-framework-vue3": "^4.2.0",
    "@tarojs/plugin-html": "^4.2.0",
    "@tarojs/runtime": "^4.2.0",
    "@tarojs/taro": "^4.2.0",
    "dayjs": "^1.11.21",
    "pinia": "^3.0.4",
    "taro-plugin-pinia": "^1.0.0",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@ntnyq/eslint-config": "^7.0.0-beta.10",
    "@tarojs/cli": "^4.2.0",
    "@tarojs/helper": "^4.2.0",
    "@tarojs/plugin-platform-weapp": "^4.2.0",
    "@tarojs/router": "^4.2.0",
    "@tarojs/shared": "^4.2.0",
    "@tarojs/webpack5-runner": "^4.2.0",
    "@types/webpack-env": "^1.18.8",
    "@vue/babel-plugin-jsx": "^3.0.0",
    "@vue/compiler-sfc": "^3.5.39",
    "babel-preset-taro": "^4.2.0",
    "bumpp": "^11.1.0",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "npm-run-all2": "^9.0.2",
    "oxfmt": "^0.57.0",
    "postcss": "^8.5.16",
    "taro-define-config": "^0.15.0",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "^6.0.3",
    "unplugin-vue-components": "^32.1.0",
    "vue-loader": "^17.4.2",
    "vue-tsc": "^3.3.6",
    "webpack": "^5.108.4"
  },
  "nano-staged": {
    "*.{js,ts,mjs,tsx,vue,md,yml,yaml,json}": "eslint --fix",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "templateInfo": {
    "name": "vue3-NutUI",
    "typescript": true,
    "css": "sass",
    "framework": "Vue3"
  }
}
